{%- set pages = sidebar_pages.split(',') | map('trim') | list -%}
"""Main application window with sidebar navigation and stacked pages."""

from __future__ import annotations

import logging
from pathlib import Path
from typing import Optional

from PySide6.QtCore import Qt
from PySide6.QtGui import QAction
from PySide6.QtWidgets import (
    QHBoxLayout,
    QMainWindow,
    QMessageBox,
    QStackedWidget,
    QVBoxLayout,
    QWidget,
)

from app.qt.db.data_store import DataStore
from app.qt.models.config_model import ConfigModel
from app.qt.state_machines.app_sm import AppStateMachine
from app.qt.views.sidebar import SidebarNav
from app.qt.views.example_page import ExamplePage
from app.qt.views.settings_dialog import SettingsDialog

logger = logging.getLogger(__name__)


class MainWindow(QMainWindow):
    def __init__(self) -> None:
        super().__init__()
        self.setWindowTitle("{{app_display_name}}")
        self.setMinimumSize(1200, 800)

        # --- Models ---
        self._config_model = ConfigModel()

        # --- State Machine ---
        self._state_machine = AppStateMachine(self)

        # --- Data Store (created when project is opened) ---
        self._data_store: Optional[DataStore] = None

        # --- Pages ---
        self._sidebar = SidebarNav()
        self._page_stack = QStackedWidget()

        self._page_0 = ExamplePage()
        self._page_stack.addWidget(self._page_0)
{% for page in pages[1:] %}
        self._page_{{loop.index}} = QWidget()  # TODO: implement {{page}} page
        self._page_stack.addWidget(self._page_{{loop.index}})
{% endfor %}
        self._sidebar.page_selected.connect(self._page_stack.setCurrentIndex)

        # --- Layout ---
        central = QWidget()
        self.setCentralWidget(central)
        layout = QHBoxLayout(central)
        layout.setContentsMargins(0, 0, 0, 0)
        layout.setSpacing(0)
        layout.addWidget(self._sidebar)
        layout.addWidget(self._page_stack, stretch=1)

        # --- Menu Bar ---
        self._build_menu_bar()

    def _build_menu_bar(self) -> None:
        menu_bar = self.menuBar()

        file_menu = menu_bar.addMenu("&File")
        settings_action = QAction("&Settings...", self)
        settings_action.triggered.connect(self._on_open_settings)
        file_menu.addAction(settings_action)
        file_menu.addSeparator()
        quit_action = QAction("&Quit", self)
        quit_action.triggered.connect(self.close)
        file_menu.addAction(quit_action)

    def _on_open_settings(self) -> None:
        dialog = SettingsDialog(
            app_config=self._config_model,
            parent=self,
        )
        dialog.exec()

    def closeEvent(self, event) -> None:
        if self._data_store:
            self._data_store.close()
        super().closeEvent(event)
