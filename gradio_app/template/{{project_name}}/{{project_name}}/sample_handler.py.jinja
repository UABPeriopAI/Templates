import tempfile

import pandas as pd


class BaseHandler:
    """
    Backend-agnostic helper for basic tabular preview and report generation.
    """

    def preview_csv(self, file_path: str):
        """
        Read a CSV file and return a small preview dataframe plus a status message.
        """
        if not file_path:
            return pd.DataFrame(), "Please upload a CSV file to proceed."

        try:
            df = pd.read_csv(file_path)
            return df.head(), "CSV file loaded successfully!"
        except Exception as exc:
            return pd.DataFrame(), f"Error reading CSV file: {exc}"

    def generate_dummy_report_text(self) -> str:
        return "Hello!\n\nThis is your dummy report generated on demand."

    def generate_dummy_report_file(self) -> str:
        """
        Write a temporary text report and return the file path for download.
        """
        report_content = self.generate_dummy_report_text()
        with tempfile.NamedTemporaryFile(
            mode="w", encoding="utf-8", suffix=".txt", delete=False
        ) as temp_file:
            temp_file.write(report_content)
            return temp_file.name


class GradioBaseHandler(BaseHandler):
    """
    UI-facing handler used by the Gradio application.
    """

    pass
